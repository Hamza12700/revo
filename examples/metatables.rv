const PointMT = {
    __tostring = fn(self) fmt("(%v, %v)", self.x, self.y),
    __add      = fn(a, b) set_metatable({x = a.x + b.x, y = a.y + b.y}, PointMT),
    dist       = fn(self) sqrt(self.x * self.x + self.y * self.y),
}

const p1 = set_metatable({x = 3, y = 0}, PointMT)
const p2 = set_metatable({x = 0, y = 4}, PointMT)
print(tostring(p1 + p2)) # (3, 4)
print((p1 + p2):dist())  # 5
